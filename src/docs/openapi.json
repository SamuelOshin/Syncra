{
  "openapi": "3.0.3",
  "info": {
    "title": "Syncra Enterprise API",
    "description": "API documentation for the Syncra Enterprise Real-Time Translation Platform backend services. Syncra uses cookie-based JWT sessions with httpOnly credentials.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Relative API base path"
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user account",
        "description": "Creates a new user profile and triggers a verification email. Returns generic success to prevent user harvesting.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "confirmPassword"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe", "minLength": 3, "maxLength": 50 },
                  "email": { "type": "string", "format": "email", "example": "john@company.com" },
                  "password": { "type": "string", "example": "StrongPass123!", "description": "Min 8 chars, 1 upper, 1 lower, 1 digit, 1 special char" },
                  "confirmPassword": { "type": "string", "example": "StrongPass123!" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration initialized successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/signin": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Authenticate user credentials",
        "description": "Validates email and password, checks email verification and lockout status, and sets session cookies (`accessToken` and `refreshToken`).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@company.com" },
                  "password": { "type": "string", "example": "StrongPass123!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful. Cookies set in header.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials or account locked/unverified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/signout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Log out active session",
        "description": "Clears httpOnly authentication cookies and increments the database token version, invalidating all other active refresh sessions.",
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get authenticated user profile details",
        "description": "Returns current session profile details by reading user ID from validated httpOnly access cookie.",
        "responses": {
          "200": {
            "description": "Profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          },
          "401": {
            "description": "Unauthenticated access",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "put": {
        "tags": ["Authentication"],
        "summary": "Update user profile details",
        "description": "Updates name, email, or translation language preference. Re-issues access cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe Updated" },
                  "email": { "type": "string", "format": "email", "example": "john@company.com" },
                  "preferredLanguage": { "type": "string", "enum": ["en", "fr", "es", "de", "ja", "pt", "it", "nl", "zh", "ru", "ar", "hi", "ko"], "default": "en" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/password": {
      "put": {
        "tags": ["Authentication"],
        "summary": "Update user password",
        "description": "Updates local password, invalidating other active devices by incrementing session version.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["currentPassword", "newPassword", "confirmNewPassword"],
                "properties": {
                  "currentPassword": { "type": "string", "example": "OldPass123!" },
                  "newPassword": { "type": "string", "example": "NewPass456!", "description": "Min 8 chars, strong rules" },
                  "confirmNewPassword": { "type": "string", "example": "NewPass456!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Request password reset link",
        "description": "Generates a password reset token and outputs reset link to the console for email recovery simulation. Always returns generic success.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@company.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset token generated if email exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Reset password using token",
        "description": "Resets the user password if the reset token is valid and unexpired.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "password", "confirmPassword"],
                "properties": {
                  "token": { "type": "string", "example": "7c5e88aa1d4d38e21759600e1cf59a58" },
                  "password": { "type": "string", "example": "NewPass456!" },
                  "confirmPassword": { "type": "string", "example": "NewPass456!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/verify-email": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Verify email token",
        "description": "Validates the verification token, marks user email verified, and redirects back to dashboard.",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "9a2f7c00e1cf59a587c5e88aa1d4d38e2"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirects to dashboard with verified parameter"
          }
        }
      }
    },
    "/auth/verify-email/resend": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Resend email verification token",
        "description": "Resends a new verification token to unverified email address.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@company.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resend process completed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/meetings": {
      "get": {
        "tags": ["Meetings"],
        "summary": "List meetings",
        "description": "Returns list of all scheduled meetings for the host user.",
        "responses": {
          "200": {
            "description": "Meetings retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Meetings"],
        "summary": "Create a new meeting room",
        "description": "Creates a WebRTC-enabled room link.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "scheduledAt"],
                "properties": {
                  "title": { "type": "string", "example": "Project Sync" },
                  "scheduledAt": { "type": "string", "format": "date-time", "example": "2026-07-02T23:30:00.000Z" },
                  "projectId": { "type": "string", "nullable": true, "example": "e45f-4a0e" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Meeting created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/meetings/{id}/verify": {
      "get": {
        "tags": ["Meetings"],
        "summary": "Verify meeting exists",
        "description": "Verifies that a meeting with the given ID exists and is not ended.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Meeting details verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/meetings/{id}/end": {
      "post": {
        "tags": ["Meetings"],
        "summary": "End active meeting",
        "description": "Marks the meeting as completed.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Meeting ended successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      }
    },
    "/glossary": {
      "get": {
        "tags": ["Glossary"],
        "summary": "List glossary terms",
        "description": "Returns list of custom terminology translation overrides.",
        "responses": {
          "200": {
            "description": "Glossary terms listed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Glossary"],
        "summary": "Create a glossary translation term override",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["sourceText", "targetText", "sourceLang", "targetLang"],
                "properties": {
                  "sourceText": { "type": "string", "example": "Lingomeet" },
                  "targetText": { "type": "string", "example": "LingoMeet App" },
                  "sourceLang": { "type": "string", "example": "en" },
                  "targetLang": { "type": "string", "example": "es" },
                  "projectId": { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Glossary term added"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SuccessEnvelope": {
        "type": "object",
        "required": ["status", "status_code", "message", "data"],
        "properties": {
          "status": { "type": "string", "example": "success" },
          "status_code": { "type": "integer", "example": 200 },
          "message": { "type": "string", "example": "Operation completed successfully" },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "items": []
            }
          }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["status", "status_code", "message", "error_code", "errors"],
        "properties": {
          "status": { "type": "string", "example": "failure" },
          "status_code": { "type": "integer", "example": 400 },
          "message": { "type": "string", "example": "Validation failed" },
          "error_code": { "type": "string", "example": "VALIDATION_ERROR" },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            },
            "example": {
              "email": ["Invalid email format"]
            }
          }
        }
      }
    }
  }
}

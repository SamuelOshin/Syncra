PORT=3000
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database (Leave blank to automatically fallback to local SQLite)
DATABASE_URL=your_postgresql_connection_string_here

# Session Security
SESSION_SECRET=your_session_secret_here

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft OAuth2 Credentials
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Translation Providers (Optional/Configurable)
PRIMARY_TRANSLATION_PROVIDER=deepl
TRANSLATION_FALLBACK_CHAIN=google,openrouter
DEEPL_API_KEY=your_deepl_api_key_here
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
